# Google OAuth — same Client ID as backend GOOGLE_CLIENT_ID
# Create at https://console.cloud.google.com/apis/credentials
#
# Local authorized JavaScript origins:
#   http://localhost:3002
#
# Production (Cloudflare Workers build → Environment variables):
#   VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#   VITE_API_URL=https://your-api.example.com
#
# Production Google Console authorized JavaScript origins:
#   https://wiserdoc.com
#   (add your exact site origin if different)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_API_URL=
