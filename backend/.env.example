# Google OAuth — verify ID tokens from the frontend
# Must match VITE_GOOGLE_CLIENT_ID in Cloudflare / frontend
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Auth signing key (use a long random string in production)
JWT_SECRET=change-me-in-production

# Local file-based auth (no database required)
USE_FILE_AUTH=true

# Production — allow your live frontend origin(s), comma-separated
# CORS_ORIGIN=https://wiserdoc.com,https://www.wiserdoc.com
